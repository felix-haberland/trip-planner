# -----------------------------------------------------------------------------
# Vacation Planner — environment variables
#
# Copy to `.env` for local dev, or set as variables in the Railway dashboard.
# Railway sets PORT automatically; everything else is explicit.
# -----------------------------------------------------------------------------

# Required: Claude API key (https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=sk-ant-...

# --- HTTP Basic Auth (gates every route, including the static frontend) -----
# If neither AUTH_USERS nor AUTH_USERNAME+AUTH_PASSWORD is set, auth is
# DISABLED (local-dev convenience). Set at least one of these in production.
#
# Single user (simplest):
# AUTH_USERNAME=felix
# AUTH_PASSWORD=pick-a-long-strong-password
#
# Multi-user (comma-separated user:pass pairs; avoid colons in usernames):
# AUTH_USERS=felix:hunter2,guest:welcome
#
# Optional realm string shown in the browser prompt (default "Vacation Planner"):
# AUTH_REALM=My Trips

# --- Trips database ----------------------------------------------------------
# Production (Railway): Postgres connection string. Railway sets DATABASE_URL
# automatically when you attach a Postgres plugin.
# DATABASE_URL=postgresql://user:pass@host:5432/railway

# Local dev (SQLite fallback): file path for trips.db. Ignored when
# DATABASE_URL is set. Default ./trips.db (resolved from backend/ cwd).
# TRIPS_DB_PATH=./trips.db

# --- Golf library (separate SQLite) ------------------------------------------
# The curated golf-resort library lives in its own SQLite engine. Defaults to
# the bundled backend/data/golf.db shipped with the deploy. UI-driven edits
# (adding resorts/courses) write to this file.
#
# On Railway (ephemeral FS): edits are lost on redeploy unless you mount a
# volume AND set GOLF_DB_PATH to a path on it. On first boot the bundled
# snapshot is copied into place so the user doesn't start with an empty
# library.
# GOLF_DB_PATH=/data/golf.db

# --- VacationMap (read-only) -------------------------------------------------
# Defaults to the bundled copy at backend/data/vacation.db. Override only if
# you want to point at a different SQLite snapshot.
# VACATIONMAP_DB_PATH=/path/to/vacation.db

# --- Other -------------------------------------------------------------------
# PORT — Railway injects automatically. Only set locally if you want a
# non-default port.
# PORT=8000

# DISABLE_TRIPS_SEED=1 — skip the first-boot seed loader. Set by conftest.py
# during tests so each test starts with a truly empty DB.
