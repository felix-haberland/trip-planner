# -----------------------------------------------------------------------------
# Vacation Planner — environment variables
#
# Copy to `.env` for local dev, or set as variables in the Railway dashboard
# for deploy. Railway sets PORT automatically; everything else is explicit.
# -----------------------------------------------------------------------------

# Required: Claude API key (https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=sk-ant-...

# Trips database path (read-write). On Railway, point at a mounted volume so
# the data survives restarts. Locally, the default `./trips.db` is fine.
#   Railway: attach a volume at /data and set TRIPS_DB_PATH=/data/trips.db
TRIPS_DB_PATH=/data/trips.db

# Read-only VacationMap data. If unset, the app uses the bundled copy at
# `backend/data/vacation.db` (shipped with the deploy). Override only if you
# want to point at a different file (e.g. a mounted volume copy).
# VACATIONMAP_DB_PATH=/data/vacation.db

# Optional: Railway sets PORT automatically. Only set locally if you want a
# non-default port.
# PORT=8000
